---
import BaseLayout from "../../layouts/BaseLayout.astro";

const recipes = [
  { title: "Pasta e Ceci", href: "/meals/pasta-e-ceci/" },
  { title: "Salmon Fishcakes", href: "/meals/salmon-fishcake/" },
];
---
<BaseLayout title="Meals">
  <div class="window">
    <div class="titlebar">
      <a class="closebox" href="/" aria-label="Close and return home"></a>
      <span class="title">Meals</span>
      <span class="zoombox"></span>
    </div>
    <div class="window-body">
      <p style="margin: 0 0 18px; line-height: 1.6;">A small, growing collection of recipes I actually cook.</p>
      <div class="icon-grid">
        {recipes.map((r) => (
          <a class="icon-item" href={r.href}>
            <svg viewBox="0 0 34 42"><rect x="2" y="2" width="30" height="38" fill="#fff" stroke="#000" stroke-width="1.5"/><rect x="7" y="9" width="20" height="2" fill="#000"/><rect x="7" y="15" width="20" height="2" fill="#000"/><rect x="7" y="21" width="14" height="2" fill="#000"/></svg>
            <span class="label">{r.title}</span>
          </a>
        ))}
      </div>
    </div>
    <div class="statusbar">{recipes.length} items in this window</div>
  </div>
</BaseLayout>
