---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLocations } from "../../data/photos";

const locations = getLocations();
---
<BaseLayout title="Photography">
  <div class="window">
    <div class="titlebar">
      <span class="closebox"></span>
      <span class="title">Photos</span>
      <span class="zoombox"></span>
    </div>
    <div class="window-body">
      <p style="margin: 0 0 18px; line-height: 1.6;">
        Just getting started &mdash; shooting on my phone for now until I get a proper camera. Photos are grouped by where they were taken; open a folder to see what's inside.
      </p>
      <div class="icon-grid">
        {locations.map((loc) => (
          <a class="icon-item" href={`/photography/${loc.slug}/`}>
            <svg viewBox="0 0 42 34"><path d="M2 6 h14 l3 4 h21 v22 h-38 z" fill="#e8d9a8" stroke="#000" stroke-width="1.5"/></svg>
            <span class="label">{loc.name}</span>
          </a>
        ))}
      </div>
    </div>
    <div class="statusbar">{locations.length} folders in this window</div>
  </div>
</BaseLayout>
