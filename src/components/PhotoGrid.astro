---
import type { Photo } from "../data/photos";

interface Props {
  photos: Photo[];
}

const { photos } = Astro.props;
---
<div class="sort-bar">
  <span class="sort-label">Sort by:</span>
  <button class="sort-btn active" data-sort="newest">Newest first</button>
  <button class="sort-btn" data-sort="oldest">Oldest first</button>
</div>

<div class="icon-grid photo-icon-grid"></div>

<div class="preview-overlay">
  <div class="window preview-window">
    <div class="titlebar">
      <span class="closebox lightbox-close"></span>
      <span class="title">Preview</span>
      <span class="zoombox"></span>
    </div>
    <div class="window-body preview-body">
      <img class="lightbox-img" src="" alt="" />
      <p class="lightbox-caption"></p>
      <p class="lightbox-meta"></p>
      <div class="preview-controls">
        <button class="mac-button lightbox-prev">&larr; Previous</button>
        <button class="mac-button lightbox-next">Next &rarr;</button>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ photos }}>
  (function () {
    const scriptEl = document.currentScript;
    const root = scriptEl.closest(".window-body") || scriptEl.parentElement || document;

    const grid = root.querySelector(".photo-icon-grid");
    const lightbox = root.querySelector(".preview-overlay");
    const lightboxImg = root.querySelector(".lightbox-img");
    const lightboxCaption = root.querySelector(".lightbox-caption");
    const lightboxMeta = root.querySelector(".lightbox-meta");
    const closeBtn = root.querySelector(".lightbox-close");
    const prevBtn = root.querySelector(".lightbox-prev");
    const nextBtn = root.querySelector(".lightbox-next");
    const sortBtns = root.querySelectorAll(".sort-btn");

    let order = [...photos];
    let current = 0;

    function formatDate(iso) {
      return new Date(iso).toLocaleDateString("en-GB", {
        day: "numeric",
        month: "long",
        year: "numeric",
      });
    }

    function sortOrder(mode) {
      const arr = [...photos];
      arr.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
      if (mode === "oldest") arr.reverse();
      return arr;
    }

    function renderGrid() {
      grid.innerHTML = "";
      order.forEach((photo, i) => {
        const btn = document.createElement("button");
        btn.className = "icon-item photo-thumb";
        btn.dataset.index = String(i);
        btn.setAttribute("aria-label", `Open ${photo.alt}`);

        const img = document.createElement("img");
        img.src = photo.src;
        img.alt = photo.alt;
        img.loading = "lazy";

        const label = document.createElement("span");
        label.className = "label";
        label.textContent =
          photo.caption.length > 22 ? photo.caption.slice(0, 20) + "…" : photo.caption;

        btn.appendChild(img);
        btn.appendChild(label);
        btn.addEventListener("click", () => openPhoto(i));
        grid.appendChild(btn);
      });
    }

    function render() {
      const photo = order[current];
      lightboxImg.src = photo.src;
      lightboxImg.alt = photo.alt;
      lightboxCaption.textContent = photo.caption;
      lightboxMeta.textContent = `${photo.location} · ${formatDate(photo.date)}`;
    }

    function openPhoto(index) {
      current = index;
      render();
      lightbox.classList.add("is-open");
    }

    function closePhoto() {
      lightbox.classList.remove("is-open");
    }

    function step(delta) {
      current = (current + delta + order.length) % order.length;
      render();
    }

    sortBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        sortBtns.forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");
        order = sortOrder(btn.dataset.sort);
        renderGrid();
      });
    });

    closeBtn.addEventListener("click", closePhoto);
    prevBtn.addEventListener("click", () => step(-1));
    nextBtn.addEventListener("click", () => step(1));
    lightbox.addEventListener("click", (e) => {
      if (e.target === lightbox) closePhoto();
    });
    document.addEventListener("keydown", (e) => {
      if (!lightbox.classList.contains("is-open")) return;
      if (e.key === "Escape") closePhoto();
      if (e.key === "ArrowLeft") step(-1);
      if (e.key === "ArrowRight") step(1);
    });

    renderGrid();
  })();
</script>

<!--
  Note: styling for this component lives in src/styles/global.css (not a
  scoped <style> block here). Astro's scoped component CSS is only loaded on
  pages that directly render the component, but our floating-window system
  fetches OTHER pages' HTML fragments and injects them into the current page
  without their <head>/CSS. Keeping this component's styles global guarantees
  they're present no matter which page a photo window is opened from.
-->

