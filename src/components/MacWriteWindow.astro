---
interface Props {
  title: string;
  backHref: string;
  status?: string;
}
const { title, backHref, status = "Read only" } = Astro.props;
---
<div class="window mw-window">
  <div class="titlebar">
    <a class="closebox" href={backHref} aria-label="Close and return"></a>
    <span class="title">{title}</span>
    <span class="zoombox"></span>
  </div>
  <div class="mw-ruler">
    <span class="mw-indent mw-indent-top"></span>
    <span class="mw-indent mw-indent-bottom"></span>
    <span class="mw-tab" style="left:210px"></span>
    <span class="mw-tab" style="left:400px"></span>
  </div>
  <div class="mw-page">
    <slot />
  </div>
  <div class="statusbar">{status}</div>
</div>

<!--
  Note: styling for this component lives in src/styles/global.css (not a
  scoped <style> block here) so it's guaranteed to be present when this
  window is opened via the floating-window AJAX system from another page.
  See the matching note in PhotoGrid.astro.
-->

